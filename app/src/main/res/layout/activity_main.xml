<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF5F7"
    tools:context=".Home.HomeFragment">

    <View
        android:id="@+id/background_header"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="#F8BBD0"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toTopOf="parent"
        app:title="Home Dashboard"
        app:titleTextColor="@android:color/white" />

    <TextView
        android:id="@+id/tvWelcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="20dp"
        android:text="Selamat Datang,"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar" />

    <TextView
        android:id="@+id/tvDaftarPertemuan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:text="Daftar Pertemuan"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvWelcome" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:clipToPadding="false"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvDaftarPertemuan">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPertemuan2"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="#FFFFFF"
                android:text="Pertemuan 2"
                android:textAllCaps="false"
                android:textColor="#AD1457"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_edit"
                app:iconTint="#F06292"
                app:strokeColor="#F48FB1"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPertemuan3"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="#FFFFFF"
                android:text="Pertemuan 3"
                android:textAllCaps="false"
                android:textColor="#AD1457"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_edit"
                app:iconTint="#F06292"
                app:strokeColor="#F48FB1"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPertemuan4"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="#FFFFFF"
                android:text="Pertemuan 4"
                android:textAllCaps="false"
                android:textColor="#AD1457"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_edit"
                app:iconTint="#F06292"
                app:strokeColor="#F48FB1"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPertemuan5"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="#FFFFFF"
                android:text="Pertemuan 5"
                android:textAllCaps="false"
                android:textColor="#AD1457"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_edit"
                app:iconTint="#F06292"
                app:strokeColor="#F48FB1"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPertemuan7"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="#FFFFFF"
                android:text="Pertemuan 7"
                android:textAllCaps="false"
                android:textColor="#AD1457"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_edit"
                app:iconTint="#F06292"
                app:strokeColor="#F48FB1"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPertemuan9"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="24dp"
                android:backgroundTint="#F06292"
                android:text="Pertemuan 9 (Active)"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_login"
                app:iconTint="#FFFFFF" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:backgroundTint="#D32F2F"
                android:text="Keluar Aplikasi"
                android:textAllCaps="false"
                app:cornerRadius="28dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>